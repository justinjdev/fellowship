{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/plugin/hooks/scripts/ensure-binary.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash|Agent|Skill|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/fellowship/bin/fellowship hook gate-guard",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "SendMessage",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/fellowship/bin/fellowship hook gate-submit",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/fellowship/bin/fellowship hook completion-guard",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/fellowship/bin/fellowship hook gate-prereq",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/fellowship/bin/fellowship hook metadata-track",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
