{
  "description": "Fellowship gate state machine — enforces phase gates for quest teammates. PreToolUse hooks block tool calls at unapproved gates (gate-guard), intercept SendMessage for gate submissions (gate-submit), and prevent premature task completion (completion-guard). PostToolUse hooks track skill invocations for phase prerequisites (gate-prereq) and task metadata updates (metadata-track).",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash|Agent|Skill|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/gate-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "SendMessage",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/gate-submit.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/completion-guard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/gate-prereq.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/metadata-track.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
